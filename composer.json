{
    "name": "crazy-goat/elephas",
    "description": "PHP client for TigerBeetle – high-performance financial transactions database",
    "keywords": [
        "tigerbeetle",
        "database",
        "financial",
        "transactions",
        "client",
        "ffi",
        "oltp",
        "double-entry"
    ],
    "homepage": "https://github.com/crazy-goat/elephas",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Piotr Halas",
            "email": "halaspiotr@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-ffi": "*"
    },
    "require-dev": {
        "php-cs-fixer/shim": "^3.75",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "suggest": {
        "ext-gmp": "For faster 128-bit arithmetic and string conversion",
        "ext-bcmath": "For 128-bit arithmetic operations"
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\Elephas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CrazyGoat\\Elephas\\Test\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "block-insecure": true,
            "abandoned": "report"
        }
    },
    "scripts": {
        "post-install-cmd": "php bin/install-git-hook.php",
        "post-update-cmd": "php bin/install-git-hook.php",
        "test": [
            "@test-unit",
            "@test-functional"
        ],
        "test-unit": "vendor/bin/phpunit --testsuite=unit",
        "test:unit": "@test-unit",
        "test-functional": "bin/run-functional-tests.sh",
        "test:functional": "@test-functional",
        "lint": [
            "vendor/bin/php-cs-fixer fix -v --dry-run",
            "vendor/bin/phpstan analyse --memory-limit=512M",
            "vendor/bin/rector process --dry-run"
        ],
        "lint-fix": [
            "vendor/bin/php-cs-fixer fix -v",
            "vendor/bin/rector process"
        ]
    }
}
